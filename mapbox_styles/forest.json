            ],
            "paint": {
                "line-color": "#8a7040",
                "line-width": 0.5,
                "line-opacity": 0.4,
                "line-dasharray": [
                    4,
                    2
                ]
            }
        },
        {
            "id": "road-path-trail",
            "type": "line",
