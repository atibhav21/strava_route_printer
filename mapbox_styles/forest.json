        {
            "id": "waterway",
            "type": "line",
            "source": "composite",
            "source-layer": "waterway",
            "paint": {
                "line-color": "#b0c89a",
                "line-width": [
                    "interpolate",
                    [
                        "linear"
                    ],
                    [
                        "zoom"
                    ],
                    8,
                    0.5,
                    14,
                    2
                ]
            }
        },
        {
            "id": "admin-boundary",
            "type": "line",
            "source": "composite",
            "source-layer": "admin",
            "filter": [
                "==",
                [
                    "get",
                    "admin_level"
                ],
