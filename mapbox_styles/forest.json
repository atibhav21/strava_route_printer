                    [
                        "zoom"
                    ],
                    10,
                    0.3,
                    14,
                    1
                ],
                "line-dasharray": [
                    2,
                    2
                ]
            }
        },
        {
            "id": "road-motorway-trunk",
            "type": "line",
            "source": "composite",
            "source-layer": "road",
            "filter": [
                "in",
                [
                    "get",
                    "class"
                ],
                [
                    "literal",
                    [
                        "motorway",
                        "trunk"
                    ]
                ]
            ],
            "paint": {
                "line-color": "#c8aa70",
                "line-width": [
                    "interpolate",
                    [
                        "linear"
                    ],
                    [
                        "zoom"
                    ],
                    8,
                    0.8,
                    14,
                    2.5
                ]
            }
        },
        {
            "id": "road-primary-secondary",
            "type": "line",
            "source": "composite",
            "source-layer": "road",
            "filter": [
                "in",
                [
                    "get",
                    "class"
                ],
                [
                    "literal",
                    [
                        "primary",
                        "secondary"
                    ]
                ]
            ],
            "paint": {
                "line-color": "#c0a060",
                "line-width": [
                    "interpolate",
                    [
                        "linear"
                    ],
                    [
                        "zoom"
                    ],
                    8,
                    0.5,
                    14,
                    2
                ]
            }
        },
        {
            "id": "road-street-tertiary",
            "type": "line",
            "source": "composite",
            "source-layer": "road",
            "filter": [
                "in",
                [
                    "get",
